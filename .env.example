# =============================================================
# ML Feature Engineering Pipeline — Environment Variables
# Copy this file to .env and fill in the values.
# Do NOT commit the .env file to version control.
# =============================================================

# ── Kafka ──────────────────────────────────────────────────
# Internal Docker network address used by all services
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
# External port exposed on the host (for local tooling)
KAFKA_EXTERNAL_PORT=9092

# ── Zookeeper ──────────────────────────────────────────────
ZOOKEEPER_CLIENT_PORT=2181

# ── Kafka Topic Names ──────────────────────────────────────
TOPIC_USER_EVENTS=user-events
TOPIC_CONTENT_METADATA=content-metadata
TOPIC_FEATURE_STORE=feature-store
TOPIC_FLINK_METRICS=flink-metrics

# ── Flink ──────────────────────────────────────────────────
# Port for the Flink Web UI / REST API
FLINK_UI_PORT=8081

# ── Producer / Dashboard ───────────────────────────────────
# Port for the primary Spring Boot producer + dashboard instance
PRODUCER_PORT=8080
# Port for the secondary dashboard instance (named 'dashboard' service)
DASHBOARD_PORT=8082
SERVER_PORT=8080

# Kafka consumer group ID (can be overridden per instance)
SPRING_KAFKA_CONSUMER_GROUP_ID=dashboard-group
